# Shopify App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders

# Admin Access Token (REQUIRED for direct API calls)
ADMIN_API=shpat_...

# Shopify Store Domain (e.g. your-store.myshopify.com)
SHOPIFY_STORE_DOMAIN=your_store_domain

# App Configuration
APP_URL=https://your-app-url.railway.app
PORT=3000

# Database
DATABASE_URL=postgresql://user:pass@host:port/db?sslmode=require

# Session Secret
SESSION_SECRET=a_random_secure_string
